# ─── Return App Environment Variables ──────────────────────────────────────
# Copy this file to `.env` and fill in your Supabase project credentials.
# These values are exposed to the client-side bundle via Expo's
# EXPO_PUBLIC_ prefix convention.
#
# Never commit the actual .env file to version control.

# Supabase project URL (from Settings > API in the Supabase dashboard)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anonymous (public) key (from Settings > API)
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
