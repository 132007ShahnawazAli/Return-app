<?xml version="1.0" encoding="utf-8"?>
<!--
  Accessibility service configuration for AppBlockAccessibilityService.
  Only listens to window state changes to detect foreground app switches.
  No content capture, no touch events — minimal permissions per Play Store policy.
-->
<accessibility-service
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:accessibilityEventTypes="typeWindowStateChanged"
    android:accessibilityFeedbackType="feedbackGeneric"
    android:accessibilityFlags="flagDefault"
    android:canRetrieveWindowContent="false"
    android:notificationTimeout="200"
    android:description="@string/accessibility_service_description" />
